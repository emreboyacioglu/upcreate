          "avgComments30d": { "type": "number" },
          "avgViews30d": { "type": "number" },
          "engagementRate": { "type": "number" },
          "contentTopics": { "type": "array", "items": { "type": "string" } },
          "calculatedAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "CommerceScore": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "creatorId": { "type": "string" },
          "engagementScore": { "type": "number" },
          "intentScore": { "type": "number" },
          "commerceScore": { "type": "number" },
          "calculatedAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "CreatorListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
