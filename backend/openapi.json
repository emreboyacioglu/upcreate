          "email": { "type": "string", "format": "email" },
          "avatarUrl": { "type": "string", "format": "uri" },
          "bio": { "type": "string" }
        }
      },
      "UpdateCreator": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "maxLength": 200 },
          "email": { "type": "string", "format": "email" },
          "avatarUrl": { "type": "string", "format": "uri" },
          "bio": { "type": "string" }
        }
      },
      "AddSocialAccount": {
        "type": "object",
        "required": ["platform", "username"],
        "properties": {
          "platform": { "$ref": "#/components/schemas/Platform" },
