      "Platform": { "type": "string", "enum": ["INSTAGRAM", "TIKTOK"] },
      "CampaignStatus": {
        "type": "string",
        "enum": ["DRAFT", "ACTIVE", "PAUSED", "COMPLETED", "CANCELLED"]
      },
      "CampaignCreatorStatus": {
        "type": "string",
        "enum": [
          "AWAITING_CREATOR",
          "CREATOR_DECLINED",
          "AWAITING_BRAND",
          "BRAND_DECLINED",
          "MATCHED",
          "CONTENT_SUBMITTED",
          "CONTENT_APPROVED",
          "CONTENT_REVISION_REQUESTED",
          "PUBLISHED",
          "COMPLETED"
        ]
      },
      "UserRole": { "type": "string", "enum": ["BRAND", "CREATOR", "ADMIN"] },
      "CampaignContentStatus": {
        "type": "string",
        "enum": ["PENDING_BRAND_REVIEW", "APPROVED", "REJECTED", "REVISION_REQUESTED"]
      },
      "Creator": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email", "nullable": true },
          "avatarUrl": { "type": "string", "nullable": true },
          "bio": { "type": "string", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "SocialAccount": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "creatorId": { "type": "string" },
          "platform": { "$ref": "#/components/schemas/Platform" },
          "username": { "type": "string" },
          "profileUrl": { "type": "string", "nullable": true },
          "followerCount": { "type": "integer" },
          "isConnected": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "SocialAccountWithMetrics": {
        "allOf": [
          { "$ref": "#/components/schemas/SocialAccount" },
          {
            "type": "object",
            "properties": {
              "metrics": {
                "nullable": true,
                "allOf": [{ "$ref": "#/components/schemas/AccountMetrics" }]
              }
            }
          }
        ]
      },
      "SocialAccountDetail": {
        "allOf": [
          { "$ref": "#/components/schemas/SocialAccountWithMetrics" },
          {
            "type": "object",
            "properties": {
              "posts": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/ContentPost" }
              }
            }
          }
        ]
      },
      "ContentPost": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "accountId": { "type": "string" },
          "postId": { "type": "string", "nullable": true },
          "caption": { "type": "string", "nullable": true },
          "mediaType": { "type": "string", "nullable": true },
          "likes": { "type": "integer" },
          "commentsCount": { "type": "integer" },
          "views": { "type": "integer" },
          "postedAt": { "type": "string", "format": "date-time", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "AccountMetrics": {
        "type": "object",
        "properties": {
