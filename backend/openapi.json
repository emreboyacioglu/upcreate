          "website": { "type": "string", "format": "uri" },
          "category": { "type": "string" },
          "notes": { "type": "string" }
        }
      },
      "Campaign": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "brandId": { "type": "string" },
          "title": { "type": "string" },
          "status": { "$ref": "#/components/schemas/CampaignStatus" },
          "budget": { "type": "number", "nullable": true },
          "brief": { "type": "string", "nullable": true },
          "productInfo": { "type": "string", "nullable": true, "description": "JSON string or free text (MVP)" },
          "commissionRate": { "type": "number", "nullable": true, "description": "Percentage e.g. 12.5" },
          "startsAt": { "type": "string", "format": "date-time", "nullable": true },
          "endsAt": { "type": "string", "format": "date-time", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "CampaignDetail": {
        "type": "object",
        "description": "Campaign with brand and invited creators"
      },
      "CampaignListResponse": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "type": "object" } },
          "meta": { "$ref": "#/components/schemas/PaginationMeta" }
        }
      },
      "CreateCampaign": {
        "type": "object",
        "required": ["brandId", "title"],
        "properties": {
          "brandId": { "type": "string" },
          "title": { "type": "string", "maxLength": 300 },
          "budget": { "type": "number", "exclusiveMinimum": 0 },
          "brief": { "type": "string" },
          "productInfo": { "type": "string" },
          "commissionRate": { "type": "number", "minimum": 0, "maximum": 100 },
          "startsAt": { "type": "string", "format": "date-time" },
          "endsAt": { "type": "string", "format": "date-time" }
        }
      },
      "UpdateCampaign": {
        "type": "object",
        "properties": {
          "brandId": { "type": "string" },
          "title": { "type": "string" },
          "budget": { "type": "number" },
          "brief": { "type": "string" },
          "productInfo": { "type": "string" },
          "commissionRate": { "type": "number", "minimum": 0, "maximum": 100 },
          "startsAt": { "type": "string", "format": "date-time" },
          "endsAt": { "type": "string", "format": "date-time" }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "page": { "type": "integer" },
          "limit": { "type": "integer" },
          "total": { "type": "integer" },
          "totalPages": { "type": "integer" }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": ["email", "password", "role"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 8 },
          "role": { "$ref": "#/components/schemas/UserRole" },
          "brandName": { "type": "string" },
          "creatorName": { "type": "string" },
          "adminRegisterSecret": { "type": "string", "description": "Required for ADMIN if ADMIN_REGISTER_SECRET is set" }
        }
